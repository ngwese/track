package track:capabilities@0.1.0;

/// Host policy for optional capabilities (network, stdio) beyond mandatory storage access.
interface capabilities {
    record flags {
        /// When false, `wasi:sockets` imports are not linked.
        network: bool,
        /// Hub hostnames or URL prefixes the guest may contact when `network` is true.
        hub-allowlist: list<string>,
        stdin: bool,
        stdout: bool,
        stderr: bool,
    }

    get: func() -> flags;
}
