
/// Durable hub mutation queue in user state (SRD §5.1, §6.3).
/// Used when the sync hub is unreachable; flushed on reconnect.
interface offline-queue {
    record mutation {
        id: string,
        workspace-slug: string,
        project-eid: option<string>,
        method: string,
        path: string,
        body: option<string>,
        idempotency-key: string,
        /// RFC 3339 timestamp string.
        enqueued-at: string,
    }

    record queue-status {
        pending: u32,
        /// RFC 3339 timestamp of oldest pending item, if any.
        oldest: option<string>,
    }

    record error {
        code: error-code,
        message: string,
    }

    enum error-code {
        io-error,
        not-found,
        duplicate-id,
    }

    enqueue: func(mutation: mutation) -> result<_, error>;

    list-queued: func(workspace-slug: option<string>) -> result<list<mutation>, error>;

    /// Remove and return up to `limit` pending mutations for a workspace (FIFO).
    drain: func(workspace-slug: string, limit: u32) -> result<list<mutation>, error>;

    /// Drop acknowledged mutation ids after successful hub flush.
    ack: func(ids: list<string>) -> result<_, error>;

    get-status: func(workspace-slug: string) -> result<queue-status, error>;
}
