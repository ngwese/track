
/// Advisory lock for project state files (`.track/state.lock`).
/// Feasibility stub uses acquire/release functions; resource-based lock in a later phase.
interface project-lock {
    record error {
        code: error-code,
        message: string,
    }

    enum error-code {
        already-held,
        unavailable,
        io-error,
    }

    /// Acquire the project state lock. When `blocking` is false, returns `unavailable` if held.
    acquire: func(blocking: bool) -> result<_, error>;

    /// Release the project state lock for this invocation.
    release: func() -> result<_, error>;
}
