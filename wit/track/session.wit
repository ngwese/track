
/// Invocation context established by the host and passed to the guest at startup.
interface session {
    record invocation {
        /// Guest argv after host bootstrap flags are removed (`track` plus subcommand args).
        argv: list<string>,
        /// Host process working directory at launch.
        cwd: string,
        /// Absolute path to the project root: the directory containing `track.yaml` (SRD §3.2.1).
        project-root: option<string>,
        /// Absolute path to `track.yaml` when a project is in scope.
        manifest-path: option<string>,
        /// Resolved `track-cli` component version for this run.
        cli-version: string,
        /// Optional content digest of the loaded component artifact.
        cli-digest: option<string>,
        /// `track-host` semver.
        host-version: string,
        /// Log level for the guest (`--log-level` / `TRACK_LOG_LEVEL`).
        log-level: string,
        /// Usage text for host-only bootstrap flags (shown before guest command help).
        host-options-help: string,
    }

    /// Immutable invocation context for the component lifetime.
    get: func() -> invocation;
}
