package track:host@0.1.0;

/// Import world for the `track-cli` guest component.
world cli-guest {
    import session;
    import capabilities;
    import locations;
    import auth;
    import user-config;
    import project-lock;
    import project-state;
    import offline-queue;
    import registry;

    /// WASI Preview 2 imports are satisfied by the `wasm32-wasip2` target and linked by
    /// `track-host` via `wasmtime-wasi` (not re-declared here during feasibility stubbing).
    export wasi:cli/run@0.2.3;
}

/// Host world: implement the `track:*` interfaces and link the guest component.
world track-host {
    export session;
    export capabilities;
    export locations;
    export auth;
    export user-config;
    export project-lock;
    export project-state;
    export offline-queue;
    export registry;
}
