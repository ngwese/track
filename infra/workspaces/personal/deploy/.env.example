# Copy to .env and fill in. Never commit .env.

# PostgreSQL (hub canonical store)
POSTGRES_PASSWORD=change-me-use-openssl-rand-base64-32

# Token signing secret for PAT / agent tokens / CI tokens
TRACK_HUB_TOKEN_SECRET=change-me-use-openssl-rand-base64-48

# Bind hub API (127.0.0.1:8080 for local dev; 0.0.0.0:8080 behind reverse proxy)
HUB_BIND=127.0.0.1:8080

TRACK_LOG_LEVEL=info

# --- Client-side (not used by compose; for track auth login) ---
# TRACK_PAT=trk_pat_...
# TRACK_HUB_URL=https://track-personal.example.com
